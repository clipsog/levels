# Copy to `.env` (not committed) for local scripts like `npm run db:push-state`.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Optional: explicit target DB for shared Levels+Assets bridge.
# TARGET_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Required for `npm run db:link-assets`:
# LEVELS_SOURCE_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/LEVELS_DB
# ASSETS_SOURCE_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/ASSETS_DB
# LEVELS_PROFILE_KEY=default
# ASSETS_ROW_ID=asset-scheduler-main

# Optional: same DB as Assets (common). When set on the Levels server, bill lines
# tagged “Show in Assets” sync to shared_subscriptions on each PUT /api/state.
# Also used by `npm run db:push-state` if set.
# SHARED_FINANCE_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/postgres
